FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /bin/recif-operator ./cmd/main.go

FROM alpine:3.21

RUN apk add --no-cache ca-certificates

COPY --from=builder /bin/recif-operator /bin/recif-operator

USER 65532:65532

ENTRYPOINT ["/bin/recif-operator"]
